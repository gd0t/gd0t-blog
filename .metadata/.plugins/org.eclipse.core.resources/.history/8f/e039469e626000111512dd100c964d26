<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" xmlns:sec="http://www.thymeleaf.org/extras/spring-security" lang="en">
<head th:replace="~{fragments :: head(${post.title} + ' | DevBlog')}"></head>
<body>
    <nav th:replace="~{fragments :: navbar}"></nav>

    <div class="container mt-4" style="max-width: 800px;">
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <a th:href="@{/}" class="text-decoration-none text-secondary">&larr; Back to Home</a>
            
            <div sec:authorize="isAuthenticated()" class="d-flex gap-2">
                <a th:href="@{/post/{id}/edit(id=${post.id})}" class="btn btn-sm btn-outline-primary">Edit Post</a>
                
                <form th:action="@{/post/{id}/delete(id=${post.id})}" method="post" onsubmit="return confirm('Are you sure you want to delete this post?');">
                    <button type="submit" class="btn delete-button btn-sm btn-outline-danger" style="color: #ef4444; border-color: rgba(239, 68, 68, 0.3);">Delete</button>
                </form>
            </div>
        </div>

        <div class="card p-4 shadow-sm border-0 mb-5">
            <h1 class="card-title fw-bold pb-2" th:text="${post.title}">Title</h1>
            <p class="text-muted small mb-4 border-bottom pb-3" th:text="${#temporals.format(post.createdAt, 'MMMM dd, yyyy')}">Date</p>
            
            <div class="card-body p-0" style="white-space: pre-wrap; font-size: 1.1em;" th:text="${post.content}">
                Content goes here...
            </div>
        </div>
    </div>
    
    <div th:replace="~{fragments :: scripts}"></div>
</body>
</html>
/* ==========================================
   BASE TYPOGRAPHY & LAYOUT
   ========================================== */

/* Browsers default to 16px.
  By setting font-size to 100%, we respect the user's default browser settings.
  At the root level, 1em = 16px (unless the user changed it).
*/
body {
    font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 100%; 
    line-height: 1.6; /* Adds comfortable breathing room between lines of text */
    color: #333333;   /* A dark charcoal is easier on the eyes than pure black */
    background-color: #f8f9fa;
}

/* ==========================================
   HEADERS (H1 - H6)
   ========================================== */
h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: 1.2;      /* Headers should have tighter line spacing than paragraphs */
    margin-top: 1.5em;     /* Space above the header */
    margin-bottom: 0.5em;  /* Space below the header */
    color: #212529;
}

/* Since 1em = the inherited font size (16px), 
  we scale the headers up proportionally.
*/
h1 { font-size: 2.5em; }   /* ~40px */
h2 { font-size: 2em; }     /* ~32px */
h3 { font-size: 1.75em; }  /* ~28px */
h4 { font-size: 1.5em; }   /* ~24px */
h5 { font-size: 1.25em; }  /* ~20px */
h6 { font-size: 1em; }     /* ~16px */


/* ==========================================
   PARAGRAPHS & LISTS
   ========================================== */
p {
    font-size: 1em;        /* ~16px */
    margin-top: 0;
    margin-bottom: 1.5em;  /* Creates consistent spacing between paragraphs */
}

ul, ol {
    font-size: 1em;
    margin-top: 0;
    margin-bottom: 1.5em;
    padding-left: 2em;     /* Indents the bullet points neatly */
}

li {
    margin-bottom: 0.5em;  /* Slight spacing between individual list items */
}

a {
    color: #0d6efd;
    text-decoration: none;
    transition: color 0.2s ease-in-out; 
}

a:hover {
    color: #0a58ca;
    text-decoration: underline;
}

code {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9em;
    background-color: #e9ecef;
    padding: 0.2em 0.4em;
    border-radius: 0.2em;
    color: #d63384;
}

pre {
    background-color: #212529;
    color: #f8f9fa;
    padding: 1em;
    border-radius: 0.3em;
    overflow-x: auto;       
    margin-bottom: 1.5em;
}

pre code {
    background-color: transparent;
    color: inherit;
    padding: 0;
}
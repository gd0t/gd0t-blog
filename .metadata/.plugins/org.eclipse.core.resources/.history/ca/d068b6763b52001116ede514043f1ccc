<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <title>Create a New Post</title>
</head>
<body>

    <h1>Write a New Blog Post</h1>
    <hr>

    <form action="#" th:action="@{/new}" th:object="${post}" method="post">
        
        <div>
            <label for="title">Title:</label><br>
            <input type="text" id="title" th:field="*{title}" required style="width: 300px;">
        </div>
        <br>
        
        <div>
            <label for="content">Content:</label><br>
            <textarea id="content" th:field="*{content}" required rows="10" style="width: 300px;"></textarea>
        </div>
        <br>
        
        <button type="submit">Publish Post</button>
        
    </form>

    <br>
    <a th:href="@{/}">Back to Home</a>

</body>
</html>
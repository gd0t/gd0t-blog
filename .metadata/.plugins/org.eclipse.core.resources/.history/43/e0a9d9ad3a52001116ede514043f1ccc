<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Java Blog</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Optional: Bootstrap Icons for a little extra polish -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <!-- Logo Area -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <!-- You can replace this emoji with an <img src="..."> later -->
                <span class="fs-3 me-2">☕</span> 
                <strong>JavaDev Blog</strong>
            </a>

            <!-- Mobile Toggle Button -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navbar Links (Pushed to the right) -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- 'ms-auto' is the magic Bootstrap class that pushes this list to the right -->
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <!-- This links down to the About section on the page -->
                        <a class="nav-link" href="#about">About</a>
                    </li>
                    <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                        <a class="btn btn-primary btn-sm" th:href="@{/new}">
                            <i class="bi bi-pencil-square"></i> Write Post
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content Grid -->
    <div class="container">
        <div class="row">
            
            <!-- Left Column: Blog Posts (Takes up 8 out of 12 columns on large screens) -->
            <div class="col-lg-8">
                <h2 class="mb-4 border-bottom pb-2">Latest Articles</h2>

                <!-- Empty State -->
                <div th:if="${#lists.isEmpty(posts)}" class="alert alert-info">
                    No blog posts found! Time to write one.
                </div>

                <!-- Blog Post Cards -->
                <div th:each="post : ${posts}" class="card mb-4 shadow-sm border-0">
                    <div class="card-body">
                        <h3 class="card-title text-dark fw-bold" th:text="${post.title}">Title</h3>
                        <div class="text-muted small mb-3">
                            <i class="bi bi-calendar3"></i> 
                            <span th:text="${#temporals.format(post.createdAt, 'MMMM dd, yyyy')}">Date</span>
                        </div>
                        <p class="card-text text-secondary" th:text="${post.content}">Content goes here...</p>
                        <!-- A placeholder button for reading the full post later -->
                        <a href="#" class="text-decoration-none fw-bold">Read more →</a>
                    </div>
                </div>
            </div>

            <!-- Right Column: Sidebar / About Me (Takes up 4 out of 12 columns) -->
            <div class="col-lg-4">
                
                <!-- About Me Card -->
                <div class="card mb-4 shadow-sm border-0" id="about">
                    <div class="card-body text-center">
                        <!-- Placeholder for a profile picture -->
                        <div class="bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                            <i class="bi bi-person"></i>
                        </div>
                        <h4 class="card-title">About Me</h4>
                        <p class="card-text text-muted">
                            Hi! I'm a backend Java developer exploring the world of web development. I built this blog using Spring Boot, Thymeleaf, and Bootstrap!
                        </p>
                        <div class="d-flex justify-content-center gap-2">
                            <!-- Placeholder social links -->
                            <a href="#" class="btn btn-outline-dark btn-sm"><i class="bi bi-github"></i> GitHub</a>
                            <a href="#" class="btn btn-outline-primary btn-sm"><i class="bi bi-linkedin"></i> LinkedIn</a>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>

    <!-- Bootstrap JavaScript (Required for the mobile menu toggle to work) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

body {
    font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 100%; 
    line-height: 1.6;
    color: #333333; 
    background-color: #f8f9fa;
}

h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: 1.2;
    margin-top: 1.5em;  
    margin-bottom: 0.5em; 
    color: #212529;
}

h1 { font-size: 2.5em; }   /* ~40px */
h2 { font-size: 2em; }     /* ~32px */
h3 { font-size: 1.75em; }  /* ~28px */
h4 { font-size: 1.5em; }   /* ~24px */
h5 { font-size: 1.25em; }  /* ~20px */
h6 { font-size: 1em; }     /* ~16px */

p {
    font-size: 1em;       
    margin-top: 0;
    margin-bottom: 1.5em;
}

ul, ol {
    font-size: 1em;
    margin-top: 0;
    margin-bottom: 1.5em;
    padding-left: 2em;
}

li {
    margin-bottom: 0.5em;
}

a {
    color: #0d6efd;
    text-decoration: none;
    transition: color 0.2s ease-in-out; 
}

a:hover {
    color: #0a58ca;
    text-decoration: underline;
}

code {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9em;
    background-color: #e9ecef;
    padding: 0.2em 0.4em;
    border-radius: 0.2em;
    color: #d63384;
}

pre {
    background-color: #212529;
    color: #f8f9fa;
    padding: 1em;
    border-radius: 0.3em;
    overflow-x: auto;       
    margin-bottom: 1.5em;
}

pre code {
    background-color: transparent;
    color: inherit;
    padding: 0;
}
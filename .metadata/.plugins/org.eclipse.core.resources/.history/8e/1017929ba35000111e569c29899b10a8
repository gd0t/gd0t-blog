package com.gd0t.gd0t.model;

import java.time.LocalDateTime;

import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.PrePersist;
import jakarta.persistence.Table;

@Entity
@Table(name = "posts")
public class Post {
	
	@Id
	@GeneratedValue(strategy = GenerationType.IDENTITY)
	private Long id;
	
	@Column(nullable = false)
	private String title;
	
	// Using TEXT definition for long blog content instead of VARCHAR(255)
	@Column(columnDefinition = "TEXT", nullable = false)
	private String content;
	
	private LocalDateTime createdAt;
	
	// Just before saving a post to the database, a stamp with the current date and time will be applied
	// (so when the post was added basically)
	@PrePersist
	protected void onCreate() {
		this.createdAt = LocalDateTime.now();
	}
	
	// Default constructor required by JPA
	public Post()
}

<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Java Blog</title>
    <!-- Add Bootstrap CSS from CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <!-- Navigation Bar -->
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">DevBlog</a>
            <a class="btn btn-outline-light" th:href="@{/new}">Write Post</a>
        </div>
    </nav>

    <!-- Main Content Container -->
    <div class="container" style="max-width: 800px;">
        <h1 class="mb-4 text-center">Latest Articles</h1>

        <!-- Empty State -->
        <div th:if="${#lists.isEmpty(posts)}" class="alert alert-info text-center">
            No blog posts found! Time to write one.
        </div>

        <!-- Blog Post Cards -->
        <div th:each="post : ${posts}" class="card mb-4 shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-primary" th:text="${post.title}">Title</h2>
                <h6 class="card-subtitle mb-3 text-muted" th:text="'Published: ' + ${#temporals.format(post.createdAt, 'dd-MM-yyyy HH:mm')}">Date</h6>
                <p class="card-text" th:text="${post.content}">Content goes here...</p>
            </div>
        </div>
    </div>

</body>
</html>
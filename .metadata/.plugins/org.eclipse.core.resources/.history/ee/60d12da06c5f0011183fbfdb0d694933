
body {
    font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 100%; 
    line-height: 1.6;
    color: #333333; 
    background-color: #f8f9fa;
}

h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: 1.2;
    margin-top: 1.5em;  
    margin-bottom: 0.5em; 
    color: #212529;
}

h1 { font-size: 2.5em; }   /* ~40px */
h2 { font-size: 2em; }     /* ~32px */
h3 { font-size: 1.75em; }  /* ~28px */
h4 { font-size: 1.5em; }   /* ~24px */
h5 { font-size: 1.25em; }  /* ~20px */
h6 { font-size: 1em; }     /* ~16px */

p {
    font-size: 1em;       
    margin-top: 0;
    margin-bottom: 1.5em;
}

ul, ol {
    font-size: 1em;
    margin-top: 0;
    margin-bottom: 1.5em;
    padding-left: 2em;
}

li {
    margin-bottom: 0.5em;
}

a {
    color: #0d6efd;
    text-decoration: none;
    transition: color 0.2s ease-in-out; 
}

a:hover {
    color: #0a58ca;
    text-decoration: underline;
}

code {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9em;
    background-color: #e9ecef;
    padding: 0.2em 0.4em;
    border-radius: 0.2em;
    color: #d63384;
}

pre {
    background-color: #212529;
    color: #f8f9fa;
    padding: 1em;
    border-radius: 0.3em;
    overflow-x: auto;       
    margin-bottom: 1.5em;
}

pre code {
    background-color: transparent;
    color: inherit;
    padding: 0;
}

body {
    background: radial-gradient(circle at top right, #111524, #050608);
    background-attachment: fixed;
    font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    color: #cbd5e1;
    line-height: 1.7;
}

h1, h2, h3, h4, h5, h6 {
    color: #f8fafc;
    font-weight: 600;
    letter-spacing: 0.05em;
}

.navbar {
    background-color: rgba(5, 6, 8, 0.7) !important;
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(56, 189, 248, 0.2);
}

.navbar-brand {
    color: #e2e8f0 !important;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
}

.card {
    background-color: rgba(17, 21, 36, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    border-radius: 8px; 
    color: #cbd5e1;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3) !important;
    transition: transform 0.2s ease-in-out, box-shadow 0.2s;
}

a .card:hover, .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(56, 189, 248, 0.1) !important;
    border: 1px solid rgba(56, 189, 248, 0.3) !important;
}

a {
    color: #38bdf8;
    text-decoration: none;
    transition: all 0.3s ease;
}

a:hover {
    color: #7dd3fc;
    text-shadow: 0 0 8px rgba(56, 189, 248, 0.6);
}

.btn-primary {
    background-color: transparent;
    color: #38bdf8;
    border: 1px solid #38bdf8;
    box-shadow: 0 0 10px rgba(56, 189, 248, 0.1);
}

.btn-primary:hover {
    background-color: #38bdf8;
    color: #050608;
    box-shadow: 0 0 15px rgba(56, 189, 248, 0.5);
    border-color: #38bdf8;
}

.btn-outline-secondary, .btn-outline-primary, .btn-outline-dark {
    background-color: transparent;
    color: #cbd5e1;
    border: 1px solid rgba(203, 213, 225, 0.3);
}

.btn-outline-secondary:hover, .btn-outline-primary:hover, .btn-outline-dark:hover {
    background-color: rgba(203, 213, 225, 0.1);
    color: #f8fafc;
    border-color: #f8fafc;
}

input[type="text"], textarea, .form-control {
    background-color: rgba(5, 6, 8, 0.5) !important;
    color: #f8fafc !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
}

input[type="text"]:focus, textarea:focus, .form-control:focus {
    background-color: rgba(5, 6, 8, 0.8) !important;
    border-color: #38bdf8 !important;
    box-shadow: 0 0 0 0.25rem rgba(56, 189, 248, 0.25) !important;
}

.text-muted, .text-secondary {
    color: #94a3b8 !important;
}

.border-bottom {
    border-color: rgba(255, 255, 255, 0.1) !important;
}

.blog-posts {
	display: flex;
	flex-direction: row;
}
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <title>root@javadev:~/new_post</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" th:href="@{/css/style.css}">
</head>
<body>
    <div class="container mt-5" style="max-width: 800px;">
        
        <h2 class="mb-4 prompt">nano new_article.txt</h2>
        
        <div class="card p-4">
            <form action="#" th:action="@{/new}" th:object="${post}" method="post">
                
                <div class="mb-4">
                    <label for="title" class="fw-bold mb-2">> input_title</label>
                    <input type="text" id="title" th:field="*{title}" required placeholder="Enter transmission title...">
                </div>
                
                <div class="mb-4">
                    <label for="content" class="fw-bold mb-2">> input_payload</label>
                    <textarea id="content" th:field="*{content}" required rows="15" placeholder="Begin typing data stream..."></textarea>
                </div>
                
                <div class="d-flex justify-content-between">
                    <a th:href="@{/}" class="btn btn-outline-dark">> cd .. (Cancel)</a>
                    <button type="submit" class="btn btn-primary px-4">> chmod +x && ./publish</button>
                </div>
                
            </form>
        </div>
        
    </div>
</body>
</html>
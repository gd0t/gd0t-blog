<!DOCTYPE html>
<!-- Adding the thymeleaf template engine and spring-security plugin -->
<html xmlns:th="http://www.thymeleaf.org" xmlns:sec="http://www.thymeleaf.org/extras/spring-security" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>gd0t@space:~$</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" th:href="@{/css/style.css}">
</head>
<body>

    <nav class="navbar navbar-expand-lg mb-4">
        <div class="container">
            <a class="navbar-brand prompt" href="/">_blog</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="bi bi-list" style="color: #00FF41; font-size: 1.5rem;"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" href="/">~/home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#about">~/whoami</a></li>
                    
                    <!-- MAGIC HAPPENS HERE: sec:authorize only renders this <li> if the user is logged in! -->
                    <li class="nav-item ms-lg-3 mt-2 mt-lg-0" sec:authorize="isAuthenticated()">
                        <a class="btn btn-primary btn-sm" th:href="@{/new}">> sudo write_post</a>
                    </li>
                    
                    <!-- Optional: A logout button -->
                    <li class="nav-item ms-lg-3 mt-2 mt-lg-0" sec:authorize="isAuthenticated()">
                        <form th:action="@{/logout}" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-dark btn-sm">> exit</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <h2 class="mb-4 prompt">cat latest_articles.txt</h2>
                <div th:each="post : ${posts}" class="card mb-4">
                    <div class="card-header bg-transparent">
                        <h4 class="card-title fw-bold m-0" th:text="${post.title}">Title</h4>
                    </div>
                    <div class="card-body">
                        <!-- Truncate the text on the homepage so it's a preview -->
                        <p class="card-text" th:text="${#strings.abbreviate(post.content, 150)}">Content goes here...</p>
                        
                        <!-- This link dynamically builds the URL to /post/1, /post/2, etc. -->
                        <a th:href="@{/post/{id}(id=${post.id})}" class="fw-bold">> execute read_more.sh</a>
                    </div>
                </div>
            </div>
            
            <!-- about me takes up to 4 columns -->
            <div class="col-lg-4">
                
                <!-- About Me Card -->
                <div class="card mb-4" id="about">
                    <div class="card-header border-bottom border-success prompt bg-transparent">
                        whoami
                    </div>
                    <div class="card-body">
                        <!-- ASCII Art style avatar placeholder -->
                        <pre class="text-center mb-3" style="font-size: 0.6rem; color: #008F11;">
  .----.
 /  ..  \
|   \/   |
 \      /
  `----'
                        </pre>
                        <p class="card-text small">
                            > ACCESS GRANTED.<br>
                            > I am a backend Java developer exploring the web layer.<br>
                            > System built via Spring Boot & Thymeleaf.
                        </p>
                        <div class="d-flex flex-column gap-2 mt-3">
                            <a href="#" class="btn btn-outline-dark btn-sm text-start">> ping github.com</a>
                            <a href="#" class="btn btn-outline-dark btn-sm text-start">> ssh linkedin.com</a>
                        </div>
                    </div>
                </div>
                </div>
        </div>
    </div>
</body>
</html>
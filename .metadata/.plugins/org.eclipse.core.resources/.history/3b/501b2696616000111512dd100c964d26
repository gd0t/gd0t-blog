<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head th:replace="~{fragments :: head('Edit Post | DevBlog')}"></head>
<body>
    <nav th:replace="~{fragments :: navbar}"></nav>

    <div class="container mt-4" style="max-width: 800px;">
        <h2 class="mb-4 pb-2 border-bottom">Edit Article</h2>
        
        <div class="card p-4 shadow-sm border-0">
            <form action="#" th:action="@{/post/{id}/edit(id=${post.id})}" th:object="${post}" method="post">
                
                <div class="mb-3">
                    <label for="title" class="form-label fw-bold">Post Title</label>
                    <input type="text" id="title" th:field="*{title}" class="form-control" required>
                </div>
                
                <div class="mb-4">
                    <label for="content" class="form-label fw-bold">Post Content</label>
                    <textarea id="content" th:field="*{content}" class="form-control" required rows="15"></textarea>
                </div>
                
                <div class="d-flex justify-content-between">
                    <a th:href="@{/post/{id}(id=${post.id})}" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
                
            </form>
        </div>
    </div>
    
    <div th:replace="~{fragments :: scripts}"></div>
</body>
</html>
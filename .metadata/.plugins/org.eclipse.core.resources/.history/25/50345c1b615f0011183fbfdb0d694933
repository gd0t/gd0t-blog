<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">

<head th:replace="~{fragments :: head('Home | DevBlog')}"></head>

<body class="bg-light">
    <nav th:replace="~{fragments :: navbar}"></nav>

    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <h2 class="mb-4 pb-2 border-bottom">Latest Articles</h2>
                
                <div th:each="post : ${posts}" class="card mb-4 shadow-sm border-0">
                    <div class="card-body">
                        <h4 class="card-title fw-bold" th:text="${post.title}">Title</h4>
                        <p class="text-muted small mb-3" th:text="${#temporals.format(post.createdAt, 'MMMM dd, yyyy')}">Date</p>
                        <p class="card-text" th:text="${#strings.abbreviate(post.content, 150)}">Content goes here...</p>
                        <a th:href="@{/post/{id}(id=${post.id})}" class="text-primary text-decoration-none fw-bold">Read More &rarr;</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card mb-4 shadow-sm border-0">
                    <div class="card-body text-center">
                        <div class="bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                            <i class="bi bi-person"></i>
                        </div>
                        <h5 class="card-title fw-bold">About Me</h5>
                        <p class="card-text text-muted small">
                            Hi, I'm a backend Java developer exploring the web layer. I built this blog using Spring Boot and Thymeleaf.
                        </p>
                        <div class="d-flex justify-content-center gap-2 mt-3">
                            <a href="#" class="btn btn-outline-dark btn-sm"><i class="bi bi-github"></i> GitHub</a>
                            <a href="#" class="btn btn-outline-primary btn-sm"><i class="bi bi-linkedin"></i> LinkedIn</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div th:replace="~{fragments :: scripts}"></div>
</body>
</html>
body {
    background-color: #050505;
    font-family: 'Courier New', Courier, monospace;
}

.text-dark, .text-muted, .text-secondary {
    color: #FFF !important; 
}

.navbar {
    background-color: #000000 !important;
    border-bottom: 1px solid #5C0000;
}

.navbar-brand, .nav-link {
    color: #00FF41 !important;
    font-weight: bold;
}

a {
    color: #00FF41;
    text-decoration: none;
}

a:hover {
    color: #00FF41;
    text-shadow: 0 0 8px #00FF41; 
}

.card {
    background-color: #0A0A0A;
    border: 1px solid #008F11;
    border-radius: 0; 
}
.card-header {
    border-bottom: 1px solid #008F11 !important;
}

.btn-primary, .btn-outline-light, .btn-outline-dark, button[type="submit"] {
    background-color: transparent;
    color: #00FF41;
    border: 1px solid #00FF41;
    border-radius: 0;
    font-weight: bold;
}
.btn-primary:hover, .btn-outline-light:hover, .btn-outline-dark:hover, button[type="submit"]:hover {
    background-color: #00FF41;
    color: #000000;
    box-shadow: 0 0 10px #00FF41;
}

.prompt::before {
    content: "root@dev:~# ";
    color: #008F11;
}

input[type="text"], textarea {
    background-color: #050505;
    color: #00FF41;
    border: 1px solid #008F11;
    border-radius: 0;
    width: 100%;
    padding: 10px;
}
input[type="text"]:focus, textarea:focus {
    outline: none;
    border-color: #00FF41;
    box-shadow: 0 0 8px #00FF41;
}

body {
	color: red;
}

p {
	color: #FFF;
}

.text-dark, .text-muted, .text-secondary {
    color: #FFF !important; 
}